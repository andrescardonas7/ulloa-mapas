{
  "name": "cursor-hub",
  "version": "0.0.0",
  "private": true,
  "description": "Universal installer/sync hub for .cursor rules/skills/hooks across editors (Cursor, VS Code, OpenCode, Antigravity).",
  "type": "module",
  "scripts": {
    "sync:trailofbits": "node ./scripts/sync-trailofbits-skills.mjs",
    "sync:trailofbits:dry": "node ./scripts/sync-trailofbits-skills.mjs --dry-run",
    "sync:cyber": "node ./scripts/sync-cyber-skills.mjs",
    "sync:cyber:dry": "node ./scripts/sync-cyber-skills.mjs --dry-run",
    "sync:pm-skills": "node ./scripts/sync-pm-skills.mjs",
    "sync:pm-skills:dry": "node ./scripts/sync-pm-skills.mjs --dry-run",
    "sync:anysearch": "node ./scripts/sync-anysearch-skill.mjs",
    "sync:anysearch:dry": "node ./scripts/sync-anysearch-skill.mjs --dry-run",
    "sync:hub-skills": "node ./scripts/sync-hub-skills.mjs",
    "sync:agent-skills": "node ./scripts/sync-agent-skills.mjs",
    "sync:taste-skills": "node ./scripts/sync-taste-skills.mjs",
    "sync:taste-skills:dry": "node ./scripts/sync-taste-skills.mjs --dry-run",
    "sync:engineering-workflow": "node ./scripts/sync-engineering-workflow-skills.mjs",
    "sync:engineering-workflow:dry": "node ./scripts/sync-engineering-workflow-skills.mjs --dry-run",
    "audit:skills": "node ./scripts/audit-skills-trust.mjs",
    "audit:skills:changed": "node ./scripts/audit-skills-trust.mjs --changed-only",
    "audit:skills:deep": "node ./scripts/skills-trust-deep-scan.mjs --changed-only --skip-if-missing",
    "audit:skills:deep:require": "node ./scripts/skills-trust-deep-scan.mjs --changed-only --require-skillspector",
    "audit:skills:hub-local": "node ./scripts/audit-skills-trust.mjs --hub-local",
    "audit:skills:anthropic-cyber": "node ./scripts/audit-skills-trust.mjs --anthropic-cyber",
    "audit:skills:pm": "node ./scripts/audit-skills-trust.mjs --pm-skills",
    "verify:skills:counts": "node ./scripts/verify-skill-counts.mjs",
    "hooks:install": "node ./scripts/install-git-hooks.mjs",
    "verify": "node ./scripts/audit-skills-trust.mjs",
    "scan:repo:quick": "node ./scripts/repo-trust-scan.mjs --mode quick",
    "scan:repo:full": "node ./scripts/repo-trust-scan.mjs --mode full"
  },
  "bin": {
    "cursor-hub": "./scripts/cursor-hub.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.0.0+sha512.b4106707c7225b1748b61595953ccbebff97b54ad05d002aa3635f633b9c53cd666f7ce9b8bc44704f1fa048b9a49b55371ab2d9e9d667d1efe2ef1514bcd513"
}
